# OpenAI-compatible API (请填你自己的 key/base/model)
LLM_API_KEY=your-llm-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60

# ASR 选择：
ASR_VENDOR=baidu

# 百度短语音 REST ASR
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_DEV_PID=1537
BAIDU_CUID=ai_interpreter_windows


# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Image generation (Qianfan)
IMAGE_API_KEY=
IMAGE_MODEL=qwen-image
IMAGE_TIMEOUT=60
